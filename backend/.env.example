# Database connection URL (PostgreSQL)
DATABASE_URL=postgresql+psycopg://username:password@host:port/dbname?sslmode=require

# Groq API key for Llama 3.3 finance assistant (get key from console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret Key (generate a random string)
SECRET_KEY=fallback-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
